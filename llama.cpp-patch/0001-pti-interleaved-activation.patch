+// PTI interleave kernel: packs N activation columns from column-major into
+// row-major (interleaved) layout so adjacent-K reads hit the same cache lines.
+// Input:  y_col[N_COLS][K_blocks]  (column-major: column j at j*stride_col + k)
+// Output: y_intlv[K_blocks][N_COLS] (row-major:   block k,col j at k*N_COLS + j)
+// Launch: <<<(K_blocks+127)/128, 128>>>
+template<int N_COLS>
+static __global__ void pti_interleave_q8_1_kernel(
+        const block_q8_1 * __restrict__ y_col,
+        block_q8_1       * __restrict__ y_intlv,
+        const int K_blocks,
+        const int stride_col) {
+    const int k = blockIdx.x * blockDim.x + threadIdx.x;
+    if (k >= K_blocks) return;
+#pragma unroll
+    for (int j = 0; j < N_COLS; ++j) {
+        y_intlv[k * N_COLS + j] = y_col[j * stride_col + k];
+    }
+}
